# Angular specific
/dist/
/out-tsc/
/tmp/
/coverage/
/e2e/test-output/
/.angular/
.angular/
.vscode/
dist/

# Node modules and dependency files
/node_modules/
/yarn.lock

# Environment files
/.env

# Angular CLI and build artefacts
/.angular-cli.json
/.ng/

# TypeScript cache
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Claude Code
.claude/

# Dev drones and essentials (generated build artifacts)
src/hypercomb-web/public/dev/
src/hypercomb-web/public/content/*
# Generated by hypercomb-essentials/scripts/prepare.ts
src/hypercomb-essentials/src/**/index.ts
src/hypercomb-essentials/src/**/*-keys.ts
src/hypercomb-relay/.gitignore

# Relay runtime artifacts: copy-to-dcp.ts mirrors the build output
# to the operator's HTTP host content dir; the SQLite event DB and
# NSSM service logs are created at runtime. None are source-of-truth.
src/hypercomb-relay/content/
src/hypercomb-relay/relay.db
src/hypercomb-relay/relay.db-shm
src/hypercomb-relay/relay.db-wal
src/hypercomb-relay/relay.out.log
src/hypercomb-relay/relay.err.log
src/hypercomb-relay/relay.out-*
src/hypercomb-relay/relay.err-*

# Browser user-data dirs created by the ai-inside test drivers. The scripts now
# launch with --user-data-dir under the OS temp dir, but any stray hidden dir
# here (legacy .edge-*/.test-profile* profiles, or a future script that forgets)
# is pure browser scratch — never source/content. Real scripts are not dotfiles.
src/scripts/ai-inside/.*/

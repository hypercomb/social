// hypercomb-dev/tsconfig.json
{
  "compileOnSave": false,

  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,

    "target": "ES2022",
    "module": "preserve",

    "baseUrl": ".",

    "paths": {
      "@hypercomb/core": ["../hypercomb-core/src/index.ts"],

      "@hypercomb/essentials": ["../hypercomb-essentials/src/index.ts"],
      "@hypercomb/essentials/*": ["../hypercomb-essentials/src/*"],

      "hypercomb-essentials/*": ["../hypercomb-essentials/src/*"]
    }
  },

  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },

  "files": [],

  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.spec.json" }]
}

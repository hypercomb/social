{
  "manifest_version": 3,
  "name": "No YouTube Shorts",
  "version": "1.0.0",
  "description": "Passively hides YouTube Shorts and automatically activates Show fewer Shorts controls.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
  "action": {
    "default_title": "No YouTube Shorts",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}

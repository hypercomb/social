{
  "name": "pbs-hypercomb-shared",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "diamond-core-processor",
    "hypercomb-avatars",
    "hypercomb-cli",
    "hypercomb-core",
    "hypercomb-dev",
    "hypercomb-essentials",
    "hypercomb-sdk",
    "hypercomb-shared",
    "hypercomb-web",
    "meadowverse"
  ],
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "audit-imports": "tsx scripts/audit-imports.ts",
    "build:core": "npm --prefix hypercomb-core run build",
    "build:essentials": "npm --prefix hypercomb-essentials run build && npm run build:module && npm --prefix hypercomb-web run runtime:core",
    "build:packages": "npm run build:core && npm run build:essentials",
    "build:all": "npm run build:core && npm run build:sdk && npm run build:cli && npm run build:essentials && npm run build:web && npm run build:dev && npm run build:dcp && npm run build:avatars && npm run build:meadowverse",
    "build:web": "npm --prefix hypercomb-web run build",
    "build:dev": "npm --prefix hypercomb-dev run build",
    "build:dcp": "npm --prefix diamond-core-processor run build",
    "build:avatars": "npm --prefix hypercomb-avatars run build",
    "build:meadowverse": "npm --prefix meadowverse run build",
    "bump": "tsx scripts/bump-version.ts",
    "publish:all": "tsx scripts/publish.ts",
    "publish:core": "tsx scripts/publish.ts --core-only",
    "publish:essentials": "tsx scripts/publish.ts --essentials-only",
    "build:module": "npm --prefix hypercomb-essentials run build:module",
    "deploy:essentials": "npm --prefix hypercomb-essentials run build:module:deploy",
    "runtime:essentials": "npm run build:module && npm --prefix hypercomb-essentials run copy-to-dcp",
    "prebuild:web": "tsx scripts/prebuild.ts --target web",
    "prebuild:dev": "tsx scripts/prebuild.ts --target dev",
    "build:sdk": "npm --prefix hypercomb-sdk run build",
    "build:cli": "npm --prefix hypercomb-cli run build",
    "start": "concurrently --names web,dev --prefix-colors blue,green \"npm --prefix hypercomb-web start\" \"npm --prefix hypercomb-dev start\"",
    "start:web": "npm --prefix hypercomb-web start",
    "start:dev": "npm --prefix hypercomb-dev start",
    "start:dcp": "npm --prefix diamond-core-processor start",
    "start:relay": "node hypercomb-relay/setup.js",
    "sync:angular": "tsx scripts/sync-angular.ts",
    "intel:extract": "tsx scripts/intel-extract.ts",
    "intel:add": "tsx scripts/intel-add.ts",
    "intel:remove": "tsx scripts/intel-remove.ts",
    "intel:publish": "tsx scripts/intel-publish.ts",
    "intel:context": "tsx scripts/intel-context.ts",
    "intel:emit-leaves": "tsx scripts/intel-emit-leaves.ts",
    "intel:build-tree": "tsx scripts/intel-build-tree.ts",
    "intel:build-hive": "tsx scripts/intel-build-hive.ts"
  },
  "dependencies": {
    "@angular/animations": "21.2.4",
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/material": "21.2.2",
    "@angular/platform-browser": "21.2.4",
    "@angular/platform-browser-dynamic": "21.2.4",
    "@angular/router": "21.2.4",
    "@angular/youtube-player": "21.2.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "highlight.js": "^11.11.1",
    "localstorage-slim": "^2.7.1",
    "parse-svg-path": "^0.1.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.6.2",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.5",
    "@angular/build": "21.2.5",
    "@angular/cli": "21.2.5",
    "@angular/compiler-cli": "21.2.4",
    "@types/awesome-notifications": "^3.1.5",
    "@types/cropperjs": "^1.3.0",
    "@types/eventemitter3": "^2.0.2",
    "@types/jasmine": "~3.10.0",
    "@types/node": "^22.5.0",
    "@types/open-graph": "^0.2.2",
    "@types/three": "^0.157.2",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "babel-plugin-transform-typescript-metadata": "^0.3.2",
    "concurrently": "^9.2.1",
    "dexie-export-import": "^4.1.4",
    "eslint": "^9.34.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "fast-check": "^4.3.0",
    "jasmine-core": "~4.0.0",
    "js-logger": "^1.6.1",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.1.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-morph": "^26.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}

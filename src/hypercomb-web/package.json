{
  "name": "hypercomb-web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prestart": "npm run prebuild:web --prefix ..",
    "start": "ng serve --port 4200 --host localhost --configuration development",
    "build": "ng build",
    "runtime": "npm run runtime:core ; npm run runtime:pixi",
    "runtime:core": "node ./scripts/build-core-vendor.cjs",
    "runtime:pixi": "npx tsx ./scripts/build-pixi-vendor.ts"
  },
  "overrides": {
    "undici": "7.24.1"
  },
  "dependencies": {
    "@angular/animations": "21.2.4",
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/material": "21.2.2",
    "@angular/platform-browser": "21.2.4",
    "@angular/router": "21.2.4",
    "@hypercomb/core": "file:../hypercomb-core",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.2",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/cli": "21.2.2",
    "@angular/build": "21.2.2",
    "@angular/compiler-cli": "21.2.4",
    "esbuild": "^0.27.0",
    "ng-packagr": "21.2.0",
    "pixi.js": "^8.16.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}

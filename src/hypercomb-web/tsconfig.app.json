{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],

    // -------------------------------------------------
    // DEV SOURCE MAPPING (CRITICAL)
    // -------------------------------------------------
    // makes @hypercomb/hello resolve to source
    // instead of node_modules
    // -------------------------------------------------
    "baseUrl": ".",
    "paths": {
      "@essentials/hello": [
        "../hypercomb-essentials/src/hello-world/hello-world.entry.ts"
      ]
    }
  },
  "files": ["src/main.ts"],
  "include": ["src/**/*.d.ts"]
}

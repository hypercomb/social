{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],

    // -------------------------------------------------
    // DEV SOURCE MAPPING (CRITICAL)
    // -------------------------------------------------
    // makes @hypercomb/essentials resolve to source
    // instead of node_modules
    // -------------------------------------------------
    "baseUrl": ".",
    "paths": {
      "@hypercomb/essentials": [
        "../hypercomb-essentials/src/index.ts"
      ]
    }
  },
  "files": [
    "src/main.ts"
  ],
  "include": [
    "src/**/*.d.ts"
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",

    // 🔥 ESM clean mode
    "module": "ESNext",
    "moduleResolution": "bundler",

    // Required for ESM + .js specifiers in TS
    "isolatedModules": true,
    "allowImportingTsExtensions": false,

    // Output
    "outDir": "dist",
    "rootDir": "src",

    // Declarations
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,

    // Clean behavior
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Helps Angular + Vite + ESM environments
    "resolveJsonModule": true,
    "esModuleInterop": false
  },
  "include": ["src", "../hypercomb-shared/ui/search-bar/resource-message-handler.ts", "../hypercomb-shared/ui/search-bar/resource-completion.service.ts", "../hypercomb-shared/ui/search-bar/completion-utility.ts", "../hypercomb-shared/core/model.ts", "../hypercomb-shared/core/lineage.ts", "../hypercomb-shared/core/movement.service.ts", "../hypercomb-shared/core/navigation.ts"]
}

{
  "name": "@hypercomb/sdk",
  "version": "0.1.0",
  "description": "Facade SDK for the Hypercomb framework — unified IoC, keys, and build API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hypercomb",
    "sdk",
    "ioc",
    "facade"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/hypercomb/social.git",
    "directory": "src/hypercomb-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hypercomb/core": "^0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
